# GitHub Intelligence Station — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

GITHUB_TOKEN=            # GitHub Personal Access Token (read:public_repo scope)
ANTHROPIC_API_KEY=       # Anthropic Claude API Key

SCOUT_INTERVAL_HOURS=6   # How often the Scout agent runs (default: 6)
MAX_REPOS_PER_DOMAIN=10  # Max repos to analyze per domain per run (default: 10)
